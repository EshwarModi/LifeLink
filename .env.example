# LifeLink Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True

# ── Security (REQUIRED in production — use a long random string) ───────────
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# ── Database ───────────────────────────────────────────────────────────────
# Local SQLite (default for development):
DATABASE_URL=sqlite:///lifelink.db

# PostgreSQL (for production / Docker):
# DATABASE_URL=postgresql://user:password@host:5432/lifelink

# ── Docker Postgres (only used by docker-compose) ─────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lifelink

# ── Application ────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=5000

# ── Cookie Security (set to true behind HTTPS in production) ──────────────
SESSION_COOKIE_SECURE=false

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
